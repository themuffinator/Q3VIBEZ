{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Q3VIBE Client (Windows Debug)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}\\build\\windows-clangcl-debug\\quake3e.x64.exe",
      "cwd": "${workspaceFolder}\\build\\windows-clangcl-debug",
      "console": "integratedTerminal",
      "stopAtEntry": false
    },
    {
      "name": "Q3VIBE Dedicated (Windows Debug)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}\\build\\windows-clangcl-debug\\quake3e.ded.x64.exe",
      "cwd": "${workspaceFolder}\\build\\windows-clangcl-debug",
      "console": "integratedTerminal",
      "stopAtEntry": false
    },
    {
      "name": "Q3VIBE Client (Linux Debug)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/linux-debug/quake3e.x64",
      "cwd": "${workspaceFolder}/build/linux-debug",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "externalConsole": false,
      "stopAtEntry": false
    },
    {
      "name": "Q3VIBE Dedicated (Linux Debug)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/linux-debug/quake3e.ded.x64",
      "cwd": "${workspaceFolder}/build/linux-debug",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "externalConsole": false,
      "stopAtEntry": false
    },
    {
      "name": "Q3VIBE Client (macOS x86_64 Debug)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/macos-debug/quake3e.x86_64",
      "cwd": "${workspaceFolder}/build/macos-debug",
      "MIMode": "lldb",
      "miDebuggerPath": "/usr/bin/lldb",
      "externalConsole": false,
      "stopAtEntry": false
    },
    {
      "name": "Q3VIBE Dedicated (macOS x86_64 Debug)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/macos-debug/quake3e.ded.x86_64",
      "cwd": "${workspaceFolder}/build/macos-debug",
      "MIMode": "lldb",
      "miDebuggerPath": "/usr/bin/lldb",
      "externalConsole": false,
      "stopAtEntry": false
    },
    {
      "name": "Q3VIBE Client (macOS aarch64 Debug)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/macos-debug/quake3e.aarch64",
      "cwd": "${workspaceFolder}/build/macos-debug",
      "MIMode": "lldb",
      "miDebuggerPath": "/usr/bin/lldb",
      "externalConsole": false,
      "stopAtEntry": false
    },
    {
      "name": "Q3VIBE Dedicated (macOS aarch64 Debug)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/macos-debug/quake3e.ded.aarch64",
      "cwd": "${workspaceFolder}/build/macos-debug",
      "MIMode": "lldb",
      "miDebuggerPath": "/usr/bin/lldb",
      "externalConsole": false,
      "stopAtEntry": false
    }
  ]
}
